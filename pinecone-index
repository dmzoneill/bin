#!/usr/bin/python3
import os
import openai
import hashlib
import json
from pinecone import Pinecone, ServerlessSpec

# Retrieve Pinecone API key from environment variables
api_key = os.getenv("PINECONE_API_KEY")
if not api_key:
    raise ValueError("PINECONE_API_KEY environment variable is not set.")

# Create an instance of the Pinecone class
pc = Pinecone(api_key=api_key)

# Get the current working directory and use it as the index name
index_name = os.path.basename(os.getcwd()).replace("_", "-")  # Replacing underscores with dashes
print(f"Using index: {index_name}")

# Create an index if it doesn't already exist
if index_name not in pc.list_indexes().names():
    pc.create_index(
        name=index_name,
        dimension=1536,  # Set your dimension based on the embedding model you're using
        metric="euclidean",  # Choose the distance metric (e.g., 'euclidean' or 'cosine')
        spec=ServerlessSpec(cloud="aws", region="us-east-1")  # Region set to us-east-1
    )

# Load the cache from the JSON file (if it exists)
cache_file = "pinecone-index.json"
if os.path.exists(cache_file):
    with open(cache_file, "r") as f:
        cache = json.load(f)
else:
    cache = {}

# Function to get embeddings using the updated OpenAI API
def get_embeddings(text):
    if not text.strip():  # Check if text is empty or contains only whitespace
        raise ValueError("Input text cannot be empty.")
    
    client = openai.Client()  # Create the OpenAI client instance
    response = client.embeddings.create(input=[text], model="text-embedding-ada-002")
    # Correct access to the embedding
    return response.data[0].embedding  # Use .data[0].embedding

# Function to compute the digest (hash) of a file's contents
def get_file_digest(file_path):
    sha256 = hashlib.sha256()
    with open(file_path, "rb") as f:
        while chunk := f.read(8192):
            sha256.update(chunk)
    return sha256.hexdigest()

# Get the current working directory
codebase_dir = os.getcwd()  # This gets the directory where the script is run
print(f"Using codebase from: {codebase_dir}")

# Instantiate the Index client using the Pinecone client instance
index = pc.Index(index_name)

# Read and upload the code, while checking the file digest
for root, dirs, files in os.walk(codebase_dir):
    for file in files:
        if file.endswith(".py"):  # or whatever file types you're working with
            file_path = os.path.join(root, file)

            # Calculate the file digest
            file_digest = get_file_digest(file_path)

            # Check if the file has been processed before and if the digest has changed
            if file_path in cache and cache[file_path] == file_digest:
                print(f"Skipping {file_path}: No changes detected.")
                continue  # Skip this file if it hasn't changed

            # Process the file: read the content and generate embeddings
            with open(file_path, "r") as f:
                code = f.read()

            try:
                # Generate an embedding for the entire file or each function/class
                embedding = get_embeddings(code)
                metadata = {"file": file_path, "text": code}  # Include the raw text as metadata

                # Upload to Pinecone
                index.upsert([(file_path, embedding, metadata)])

                # Update the cache with the new digest
                cache[file_path] = file_digest
                print(f"Processed and uploaded {file_path}")

            except ValueError as e:
                # Handle specific ValueError (e.g., empty text) and continue with the next file
                print(f"Skipping {file_path}: {e}")
            except Exception as e:
                # Handle any other exceptions that may arise and continue with the next file
                print(f"Error processing {file_path}: {e}")


# Save the updated cache back to the JSON file
with open(cache_file, "w") as f:
    json.dump(cache, f, indent=4)

# Query Pinecone with an embedding
query_embedding = get_embeddings("list issues")
result = index.query(vector=query_embedding, top_k=5, include_metadata=True)
print(result)

