def create_wordpress_post(
    title: str, content: str, excerpt: str, files: List[str], featured_image_url: Optional[str] = None
) -> Optional[Dict]:
    """
    Creates a WordPress post with the provided title, content, excerpt, and files.

    Arguments:
    - title (str): The title of the WordPress post.
    - content (str): The content of the WordPress post.
    - excerpt (str): The excerpt of the WordPress post.
    - files (list): List of files to determine programming languages.

    Return:
    - dict or None: A dictionary containing the response data if the post is successfully created, otherwise None.

    Exceptions:
    - requests.exceptions.RequestException: If an error occurs during the HTTP request.
    """
    # pylint: disable=too-many-locals
    url: str = f"{WORDPRESS_URL}posts"
    creds: str = f"{WORDPRESS_USERNAME}:{WORDPRESS_APPLICATION}".encode()
    creds: str = base64.b64encode(creds).decode("utf-8")
    headers: Dict[str, str] = {
        "Content-Type": "application/json",
        "Authorization": f"Basic {creds}",
    }

    # Determine languages from the provided files
    languages: List[str] = determine_languages_from_files(files)
    if not languages:
        print("No programming languages detected in the provided files.")
        return None

    # Get tags and categories
    tag_ids: List[int] = get_or_create_tags(languages)
    categories_url: str = f"{WORDPRESS_URL}categories"
    response: requests.Response = requests.get(
        categories_url, headers=headers, params={"page": 1, "per_page": 100}, timeout=30
    )
    category_id: int = 0
    if response.status_code == 200:
        categories: List[Dict[str, str]] = response.json()
        category_id = get_category_id(languages, categories)

        if not category_id:
            print("No matching categories found. Using default category.")

    # Clean and prepare content
    clean_content: str = clean_html_code_block(content)

    for file_path in files:
        try:
            # Read the content of the file
            with open(file_path, "r", encoding="utf-8") as file:
                content: str = file.read()

            # Add the file name and content to the prompt
            search = f"# File: {os.path.basename(file_path)}"
            clean_content = clean_content.replace(search, "\n" + content + "\n")
        except Exception as e:  # pylint: disable=broad-exception-caught
            print(f"Error reading file {file_path}: {e}")
            continue

    title: str = strip_html_tags(clean_html_code_block(title))
    excerpt: str = strip_html_tags(clean_html_code_block(excerpt))

    # Get the current publish date
    publish_date: str = get_publish_date()

    post_data: Dict[str, str] = {
        "title": title,
        "content": clean_content,
        "status": "publish",
        "date": publish_date,
        "excerpt": excerpt,
        "slug": title.replace(" ", "-").lower(),
        "tags": tag_ids,
        "categories": category_id,
    }

    # If a featured image URL is provided, upload it and set it as the featured image
    if featured_image_url:
        try:
            img_data = requests.get(featured_image_url).content
            media_url = f"{WORDPRESS_URL}media"
            media_headers = {
                "Content-Disposition": f"attachment; filename={title}.jpg",
                "Content-Type": "image/jpeg",
                "Authorization": f"Basic {creds}",
            }
            media_response = requests.post(media_url, headers=media_headers, data=img_data)
            if media_response.status_code == 201:
                media_id = media_response.json().get("id")
                if media_id:
                    post_data["featured_media"] = media_id
                    post_data["content"] = post_data["content"].replace(
                        "FEATURED_IMAGE_PLACEHOLDER", media_response.json().get("source_url")
                    )
            else:
                print(f"Failed to upload featured image: {media_response.status_code} - {media_response.text}")
        except Exception as e:
            print(f"Error uploading featured image: {e}")

    try:
        response: requests.Response = requests.post(
            url, json=post_data, headers=headers, timeout=30
        )
        if response.status_code == 201:
            print(f"Post created successfully! URL: {response.json()['link']}")
            return response.json()
        print(f"Failed to create post. Status Code: {response.status_code}")
        return None

    except requests.exceptions.RequestException as e:
        print(f"Request failed: {str(e)}")
        return None


def generate_blog_post_prompt(
    files: List[str], optional_input: Optional[str] = None
) -> str:
    """
    Generate a blog post prompt based on the content of the provided files and optional input.

    Arguments:
    - files (list): A list of file paths containing the source code for the blog post.
    - optional_input (str, optional): Additional input to be included in the prompt. Defaults to None.

    Return:
    - str: A formatted prompt for generating a blog post, including the content of the files and optional input.

    The function reads the content of each file in the provided list of file paths, adds the file name and content to
    the prompt, and formats the prompt for generating a blog post. If an optional input is provided, it is included in
    the prompt as well. The function also handles exceptions that may occur while reading files.

    Side Effects:
    - May print error messages if there are issues reading files.
    """
    prompt: str = "Generate a blog post from the below source code:\n\n"

    for file_path in files:
        try:
            # Read the content of the file
            with open(file_path, "r", encoding="utf-8") as file:
                content: str = file.read()

            # Add the file name and content to the prompt
            prompt += f"File: {os.path.basename(file_path)}\n"
            prompt += f"Content:\n{content}\n\n"
        except Exception as e:  # pylint: disable=broad-exception-caught
            print(f"Error reading file {file_path}: {e}")
            continue

    prompt += "The content should be formatted in HTML for WordPress, not markdown.\n"

    if optional_input:
        prompt += f"\n\n{optional_input}\n"

    return prompt


def get_files_from_path(file_or_folder_path: str) -> List[str]:
    """
    Create an array of file paths from the given path.
    If it's a file, return an array with a single entry.
    If it's a directory, return an array of file paths recursively.

    :param file_or_folder_path: Path to a file or directory
    :return: List of file paths
    :raises ValueError: If the provided path is neither a file nor a directory
    """
    if os.path.isfile(file_or_folder_path):
        # If it's a file, return a list with a single entry
        return [file_or_folder_path]

    if os.path.isdir(file_or_folder_path):
        # If it's a directory, walk through it recursively and collect file
        # paths
        file_paths: List[str] = []
        for root, _, files in os.walk(file_or_folder_path):
            for file in files:
                file_paths.append(os.path.join(root, file))
        return file_paths

    print(
        f"The path '{file_or_folder_path}' is neither a file nor a directory.")
    sys.exit(1)


def parse_arguments() -> argparse.Namespace:
    """
    Parse command-line arguments for the script.

    Arguments:
    - No arguments needed.

    Return:
    - Returns the parsed command-line arguments as an argparse Namespace object.
    """
    parser: argparse.ArgumentParser = argparse.ArgumentParser(
        description="Process a file or directory and an optional input string."
    )
    parser.add_argument("path", type=str, help="Path to a file or directory.")
    parser.add_argument(
        "--input", type=str, help="Optional input string.", default=None
    )
    return parser.parse_args()


def main() -> None:
    """
    This function serves as the main entry point for processing a file or directory path, generating a blog post
    prompt, utilizing OpenAI to generate a title and description, preparing an SEO excerpt, and creating a WordPress
    post based on the processed data.

    Arguments:
    - No arguments are passed directly to the function. However, the function relies on the following components:
    - Command-line arguments obtained by parsing arguments using 'parse_arguments()'.
    - 'file_or_dir_path': Represents the path (file or directory) obtained from the parsed arguments.
    - 'optional_input': Represents an optional input string obtained from the parsed arguments.
    - 'files': A list of files obtained from the path using 'get_files_from_path()'.
    - 'prompt': A blog post prompt generated based on the files and optional input.
    - 'title': The title of the blog post generated using OpenAI.
    - 'description': The description of the blog post generated using OpenAI.
    - 'excerpt': The SEO excerpt derived from the description.
    - 'post_response': Response from creating a WordPress post using 'create_wordpress_post()'.

    Return:
    - No explicit return value. The function prints out various processing steps and outcomes.

    Exceptions:
    - Any exceptions raised during the main processing are caught and printed with a generic error message.

    Side Effects:
    - The function interacts with external services for generating blog content and creating a WordPress post.
    - It prints out information related to the processing steps and outcomes.
    """
    unsplash_key = os.getenv("UNSPLASH_ACCESS_KEY")
    youtube_key = os.getenv("YOUTUBE_API")

    # Parse command-line arguments
    args: argparse.Namespace = parse_arguments()
    file_or_dir_path: str = args.path
    optional_input: Optional[str] = args.input

    print(f"Processing path: {file_or_dir_path}")
    if optional_input:
        print(f"Optional input string: {optional_input}")

    files: List[str] = get_files_from_path(file_or_dir_path)

    prompt: str = generate_blog_post_prompt(files, optional_input)

    # Generate description using OpenAI
    title: Optional[str]
    description: Optional[str]
    image_idea: Optional[str]
    youtube_topics: Optional[str]

    # Generate content with media
    title, description, image_idea, youtube_topics = generate_description_with_media(prompt)

    print(title)
    print(image_idea)
    print(youtube_topics)

    if(not title or not description):
        print("Error generating title/description.")
        sys.exit(1)

    # Prepare the SEO excerpt
    excerpt: str = strip_html_tags(clean_html_code_block(description)).strip()
    # Use the first 150 characters as an SEO excerpt
    excerpt = excerpt[:150].strip()
    # Search image
    image_url = None
    if image_idea and unsplash_key:
        raw_img_url = search_image_url_unsplash(image_idea, unsplash_key)
        if raw_img_url:
            image_url = upload_image_to_wordpress(raw_img_url, title + ".jpg")

    # Search YouTube
    video_url = None
    if youtube_topics and youtube_key:
        for topic in youtube_topics:
            video_url = search_youtube_video(topic, youtube_key)
            if video_url:
                break
    # Append enrichment
    description = append_enrichment_to_post(description, video_url)

    # Create WordPress post
    post_response: Optional[Dict] = create_wordpress_post(
        title, description, excerpt, files, featured_image_url=image_url
    )
    if post_response:
        print("Created post")
    else:
        print("Failed to create post")


if __name__ == "__main__":
    main()
