    enrichment = ""
    if video_url:
        enrichment = "\n\n<hr><h2>📚 Further Learning</h2>\n"
        enrichment += f'<p>🎥 Watch this video for more:</p>\n<iframe width="710" height="415" src="{video_url}" frameborder="0" allowfullscreen></iframe>\n'
