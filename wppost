class OpenAIProvider:  # pylint: disable=too-few-public-methods
    """
    This class provides a way to interact with the OpenAI API for text completion tasks.

    Attributes:
    - api_key (str): The API key used for authentication with the OpenAI API.
    - endpoint (str): The URL endpoint for making requests to the OpenAI API.
    - model (str): The model identifier used for text completion tasks.

    Methods:
    - improve_text(prompt: str, text: str) -> str: Sends a text completion request to the OpenAI API using the provided
    prompt and text, and returns the improved text response.
    """

    def __init__(self) -> None:
        """
        Initialize the API key, endpoint, and model for OpenAI chat completions.

        Arguments:
        - self: The object instance.
        """
        self.api_key: str = os.getenv("AI_API_KEY")
        self.endpoint: str = "https://api.openai.com/v1/chat/completions"
        self.model: str = os.getenv("AI_MODEL")

    def improve_text(self, prompt: str, text: str) -> str:
        """
        Improve the given text by providing a more coherent response using the OpenAI API.

        Arguments:
        - prompt (str): The prompt to be used for generating a response.
        - text (str): The original text that needs improvement.

        Return:
        - str: The improved text generated by the OpenAI API.

        Exceptions:
        - requests.exceptions.RequestException: Raised for any request-related exceptions like network issues or
        timeouts.
        """
        headers: Dict[str, str] = {
            "Authorization": f"Bearer {self.api_key}",
            "Content-Type": "application/json",
        }

        body: Dict = {
            "model": self.model,
            "messages": [
                {"role": "system", "content": prompt},
                {"role": "user", "content": text},
            ],
            "temperature": 0.4,
        }

        try:
            # Make the API request
            response: requests.Response = requests.post(
                self.endpoint, json=body, headers=headers, timeout=120
            )

            # Check for successful response
            if response.status_code == 200:
                return response.json()[
                    "choices"][0]["message"]["content"].strip()

            # If the request fails, raise an error with the response details
            print(
                f"OpenAI API call failed: {response.status_code} - {response.text}")
            sys.exit(1)
        except requests.exceptions.RequestException as e:
            # Catch any request-related exceptions (e.g., network issues,
            # timeouts)
            print(f"Request failed: {str(e)}")
            sys.exit(1)


def determine_languages_from_files(files: List[str]) -> List[str]:
    """
    Determine the programming languages used in the provided files based on their extensions.

    :param files: List of file paths
    :return: List of unique programming languages
    """
    languages: set[str] = set()
    for file_path in files:
        _, ext = os.path.splitext(file_path)
        if ext in EXTENSION_LANGUAGE_MAP:
            languages.add(EXTENSION_LANGUAGE_MAP[ext])
    return list(languages)


def get_publish_date() -> str:
    """
    Get the current date and time in ISO 8601 format for the publish date.

    :return: String representing the current date and time in ISO 8601 format
    """
    return datetime.datetime.now().strftime("%Y-%m-%dT%H:%M:%S")


def clean_html_code_block(content: str) -> str:
    """
    Remove code block delimiters from the given content.

    Arguments:
    - content (str): A string containing HTML code block delimiters.

    Return:
    - str: The content with the start and end of code block delimiters removed.
    """
    # Remove start of code block
    content = re.sub(r"^```.*?$", "", content, flags=re.MULTILINE)
    content = re.sub(r"```$", "", content)  # Remove end of code block
    return content


def strip_html_tags(text: str) -> str:
    """
    Remove HTML tags from the input text.

    Arguments:
    - text (str): A string containing HTML tags that need to be stripped.

    Return:
    - str: The input text with all HTML tags removed.
    """
    return re.sub(r"<[^>]*>", "", text)


def generate_description(prompt: str) -> Tuple[Optional[str], Optional[str]]:
    """
    Generate a blog post description based on a provided source code prompt.

    Arguments:
    - prompt (str): The source code prompt to generate a blog post from.

    Return:
    - tuple: A tuple containing the title and description of the generated blog post.
    Returns (None, None) if an error occurs during the generation process.
    """
    user_prompt: str = prompt
    ai_provider: OpenAIProvider = OpenAIProvider()


    try:
        response: str = ai_provider.improve_text(system_prompt, user_prompt)

        print(system_prompt)
        print(response)

        title_match: Optional[re.Match] = re.search(
            r"Title:\s*(.*)", response
        )  # Match the title
        if title_match:
            title: str = title_match.group(1).strip()
            description: str = re.sub(r"Title:\s*.*\n", "", response).strip()
            return title, description
        title: str = clean_html_code_block(
            response.strip()).strip().splitlines()[0]
        return strip_html_tags(title), response.strip()

    except Exception as e:  # pylint: disable=broad-exception-caught
        print(f"Error generating description: {e}")
        return None, None


def get_or_create_tags(tags: List[str]) -> List[int]:
    """
    Retrieve existing tag IDs from a WordPress site or create new tags if they do not exist.

    Arguments:
    - tags (list): A list of strings representing the names of tags to retrieve or create.

    Return:
    - list: A list of integers containing the IDs of the existing or newly created tags.
    """
    tag_ids: List[int] = []
    tags_url: str = f"{WORDPRESS_URL}tags"
    headers: Dict[str, str] = {
        "Content-Type": "application/json",
        "Authorization": f'Basic {base64.b64encode(f"{WORDPRESS_USERNAME}:{WORDPRESS_APPLICATION}".encode()).decode()}',
    }

    response: requests.Response = requests.get(
        tags_url, headers=headers, params={"page": 1, "per_page": 100}, timeout=30
    )
    if response.status_code == 200:
        existing_tags: List[Dict[str, str]] = response.json()
        existing_tag_names: Dict[str, int] = {
            tag["name"].lower(): tag["id"] for tag in existing_tags
        }

        for tag in tags:
            tag_lower: str = tag.lower()
            if tag_lower in existing_tag_names:
                tag_ids.append(existing_tag_names[tag_lower])
            else:
                create_tag_url: str = f"{WORDPRESS_URL}tags"
                create_tag_data: Dict[str, str] = {"name": tag}
                create_response: requests.Response = requests.post(
                    create_tag_url, json=create_tag_data, headers=headers, timeout=30
                )
                if create_response.status_code == 201:
                    new_tag: Dict[str, int] = create_response.json()
                    tag_ids.append(new_tag["id"])
                else:
                    print(f"Failed to create tag '{tag}'.")
    else:
        print(f"Failed to fetch tags. Status code: {response.status_code}")

    return tag_ids


def get_category_id(languages: List[str],
                    categories: List[Dict[str, str]]) -> int:
    """
    Get the category ID based on the provided programming languages and categories.

    Arguments:
    - languages (list): A list of programming languages to search for.
    - categories (list): A list of dictionaries representing categories with "name" and "id" keys.

    Return:
    - int: The ID of the category that matches any of the provided programming languages.
    """
    category_id: int = 0

    # Loop through each category and check if any category name matches the
    # programming languages
    for category in categories:
        for language in languages:
            if language.lower() == category["name"].lower():
                category_id = category["id"]
                break

    return category_id


def search_image_url_unsplash(query: str, api_key: str) -> Optional[str]:
    url = "https://api.unsplash.com/search/photos"
    headers = {
        "Accept-Version": "v1",
        "Authorization": f"Client-ID {api_key}"
    }
    params = {
        "query": query,
        "orientation": "landscape",
        "per_page": 1
    }
    response = requests.get(url, headers=headers, params=params)
    if response.status_code == 200:
        data = response.json()
        if data["results"]:
            return data["results"][0]["urls"]["regular"]
    else:
        print(f"Unsplash API error: {response.status_code} - {response.text}")
    return None


def upload_image_to_wordpress(image_url: str, image_name: str) -> Optional[str]:
    try:
        img_data = requests.get(image_url).content
        media_url = f"{WORDPRESS_URL}media"
        headers = {
            "Content-Disposition": f"attachment; filename={image_name}",
            "Content-Type": "image/jpeg",
            "Authorization": f'Basic {base64.b64encode(f"{WORDPRESS_USERNAME}:{WORDPRESS_APPLICATION}".encode()).decode()}',
        }
        response = requests.post(media_url, headers=headers, data=img_data)
        if response.status_code == 201:
            return response.json().get("source_url")
        else:
            print(f"WordPress upload failed: {response.status_code} - {response.text}")
    except Exception as e:
        print(f"Image upload failed: {e}")
    return None


